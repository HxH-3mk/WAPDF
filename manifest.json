{
  "manifest_version": 3,
  "name": "WhatsApp Web PDF Viewer Bypass",
  "description": "تجاوز عارض PDF في واتساب ويب وتنزيل الملفات مباشرة",
  "version": "1.1",
  "icons": {
    "16": "icon.ico",
    "48": "icon.ico",
    "128": "icon.ico"
  },
  "permissions": [
    "downloads"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://web.whatsapp.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
